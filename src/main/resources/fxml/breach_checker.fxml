<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<VBox spacing="12" prefWidth="780" prefHeight="660"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.onecritto.ui.BreachCheckerController"
      styleClass="background-surface"
      style="-fx-padding: 20;">

    <!-- HEADER -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <FontAwesomeIconView glyphName="SHIELD" glyphSize="24" style="-fx-fill: #e74c3c;"/>
        <Label text="%breach.title"
               style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="summaryLabel"
               style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
    </HBox>

    <!-- DESCRIPTION -->
    <Label fx:id="descriptionLabel" text="%breach.description"
           wrapText="true" style="-fx-font-size: 12px; -fx-text-fill: #999;"/>

    <Separator/>

    <!-- PROGRESS AREA -->
    <VBox fx:id="progressBox" spacing="6" managed="false" visible="false">
        <HBox spacing="10" alignment="CENTER_LEFT">
            <ProgressBar fx:id="progressBar" prefWidth="400" prefHeight="16" progress="0"/>
            <Label fx:id="progressLabel" text="0/0" style="-fx-font-size: 12px;"/>
        </HBox>
        <Label fx:id="currentEntryLabel" style="-fx-font-size: 11px; -fx-text-fill: #888;"/>
    </VBox>

    <!-- RESULTS TABLE -->
    <TableView fx:id="resultsTable" VBox.vgrow="ALWAYS"
               style="-fx-font-size: 13px;">
        <columns>
            <TableColumn fx:id="statusColumn" text="" prefWidth="40" sortable="false"/>
            <TableColumn fx:id="titleColumn" text="%breach.col.title" prefWidth="220"/>
            <TableColumn fx:id="breachCountColumn" text="%breach.col.count" prefWidth="120"/>
            <TableColumn fx:id="detailColumn" text="%breach.col.detail" prefWidth="340"/>
        </columns>
        <placeholder><Label text="%breach.placeholder"/></placeholder>
    </TableView>

    <!-- BOTTOM BUTTONS -->
    <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 5 0 0 0;">
        <Button fx:id="scanButton" text="%breach.btn.scan" onAction="#handleScan"
                style="-fx-font-weight: bold;">
            <graphic><FontAwesomeIconView glyphName="SEARCH" glyphSize="14"/></graphic>
        </Button>
        <Button text="%close" onAction="#handleClose">
            <graphic><FontAwesomeIconView glyphName="TIMES" glyphSize="14"/></graphic>
        </Button>
    </HBox>

</VBox>
