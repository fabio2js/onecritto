<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<VBox spacing="12" prefWidth="800" prefHeight="520"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.onecritto.ui.PasswordCoachController"
      styleClass="background-surface"
      style="-fx-padding: 20;">

    <!-- HEADER -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <FontAwesomeIconView glyphName="GRADUATION_CAP" glyphSize="24" style="-fx-fill: #3574F0;"/>
        <Label text="%coach.title"
               style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="scoreLabel"
               style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
    </HBox>

    <!-- ENTRY TITLE -->
    <Label fx:id="entryTitleLabel"
           style="-fx-font-size: 14px; -fx-text-fill: #888;"/>

    <Separator/>

    <!-- STRENGTH BAR -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="%coach.strength" style="-fx-font-weight: bold;"/>
        <ProgressBar fx:id="strengthBar" prefWidth="300" prefHeight="18" progress="0"/>
        <Label fx:id="strengthLabel" style="-fx-font-size: 12px;"/>
    </HBox>

    <Separator/>

    <!-- TIPS LIST -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: transparent;">
        <VBox fx:id="tipsContainer" spacing="8">
            <padding><Insets top="5" bottom="5" left="5" right="5"/></padding>
        </VBox>
    </ScrollPane>

    <!-- CLOSE BUTTON -->
    <HBox alignment="CENTER_RIGHT" style="-fx-padding: 5 0 0 0;">
        <Button text="%close" onAction="#handleClose">
            <graphic><FontAwesomeIconView glyphName="TIMES" glyphSize="14"/></graphic>
        </Button>
    </HBox>

</VBox>
